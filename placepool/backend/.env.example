# ================================================================
#  PlacePool — Backend Environment Variables
#  1. Copy this file:  cp .env.example .env
#  2. Fill every value below
# ================================================================

PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ─────────────────────────────────────────────
# https://cloud.mongodb.com → New Project → Free Cluster
# Connect → Drivers → copy the URI, replace <password>
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/placepool?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
# Run in terminal to generate:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRE=7d

# ── Gmail SMTP (OTP emails) ───────────────────────────────────
# 1. Gmail → Settings → Security → 2-Step Verification → ON
# 2. Security → App Passwords → Mail → Generate
# 3. Paste the 16-char password below (no spaces)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=abcd efgh ijkl mnop
EMAIL_FROM=PlacePool <yourgmail@gmail.com>

# ── Cloudinary (file uploads) ─────────────────────────────────
# https://cloudinary.com → Free account → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── First Admin Account (auto-created on first run) ───────────
ADMIN_NAME=Portal Admin
ADMIN_EMAIL=admin@university.edu
ADMIN_PASSWORD=Admin@1234

# ── Frontend URL ──────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
